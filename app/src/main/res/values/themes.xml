<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme — must exist or the build fails -->
    <style name="Theme.Lingolens" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#7C4DFF</item>
        <item name="colorPrimaryVariant">#5E35B1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#BB86FC</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">#12122A</item>
        <item name="android:navigationBarColor">#0F0F1A</item>
    </style>

    <!-- Bottom sheet theme used in PdfViewerActivity -->
    <style name="BottomSheetTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>